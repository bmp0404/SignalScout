# Copy to .env for local overrides; set these in Railway → service → Variables for production.
# Placeholders only — never commit real values.

# Path to the local SQLite database file (local dev only; ignored when DATABASE_URL is set).
SIGNAL_SCOUT_DB=./signal_scout.db

# Postgres connection string; leave blank for SQLite. On Railway reference ${{Postgres.DATABASE_URL}}.
DATABASE_URL=

# GitHub personal access token (classic, public scope is enough) for live scrapers / Run Discovery.
GITHUB_TOKEN=

# Number of seed accounts processed by one discovery run. Default 4.
DISCOVERY_SEED_LIMIT=4

# Maximum candidates expanded from each discovery seed. Default 30.
DISCOVERY_MAX_PER_SEED=30

# Maximum unresolved Devpost/Scholar collaborators promoted per run. Default 15.
COLLABORATION_PROMOTION_CAP=15

# Opt in to expanding from the separately curated fellowship alumni pool.
# Off by default so the existing on-camera seed behavior is unchanged.
DISCOVERY_INCLUDE_FELLOWSHIP_SEEDS=false

# Legacy single-provider hint ("pdl" or "coresignal"). The chain is now PDL-first with a
# Coresignal fallback regardless; a provider is used whenever its key is present below.
ENRICHMENT_PROVIDER=pdl

# People Data Labs API key (https://www.peopledatalabs.com) — PRIMARY enricher + lead search lane.
PDL_API_KEY=

# Coresignal API key (https://coresignal.com) — independent search + PDL no-match fallback.
CORESIGNAL_API_KEY=

# PDL free tier is ~100 lookups/month, shared. SEARCH-FIRST split: fraction of the monthly cap
# reserved for provider-search discovery (the lead source); the rest is GitHub-enrichment.
PDL_MONTHLY_CAP=100
PDL_SEARCH_SPLIT=0.7

# Max fresh provider lookups a single run/process may spend (guards runaway backfills).
PROVIDER_PER_RUN_CAP=100

# Coresignal's OWN separate daily cap, shared across its independent search and PDL-fallback use.
CORESIGNAL_DAILY_CAP=20

# Legacy global daily counter; superseded by the provider-scoped budgets above (kept for compat).
DAILY_ENRICHMENT_BUDGET=100

# Resend API key (https://resend.com) for sending the daily email digest.
RESEND_API_KEY=

# Verified sender address for digest emails (must be on a domain verified in Resend).
DIGEST_FROM_EMAIL=

# Public app origin used in feedback and unsubscribe links (no trailing slash).
PUBLIC_BASE_URL=http://localhost:8000

# Runtime environment. Production fails closed unless CRON_SECRET is set.
APP_ENV=development

# Optional explicit owner address allowed to receive production test digests.
OWNER_TEST_EMAIL=

# Shared secret required by POST /api/digest/cron and POST /api/discovery/cron.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Background discovery ticker (in-process). Set to 0 to disable (e.g. local tests).
DISCOVERY_BACKGROUND=1
DISCOVERY_BACKGROUND_INTERVAL_HOURS=6
